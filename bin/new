#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

if [ $# -lt 1 ]; then
    echo "Usage: bin/new <project-name> [directory]"
    echo ""
    echo "Creates a new Luminus project."
    exit 1
fi

PROJECT_NAME="$1"
DIR="${2:-$PROJECT_NAME}"
DIRNAME="$(basename "$(realpath -m "$DIR")")"

if [ -d "$DIR" ]; then
    echo -e "${RED}Error:${NC} Directory '$DIR' already exists."
    exit 1
fi

echo -e "${CYAN}Creating Luminus project:${NC} $PROJECT_NAME"
echo ""

mkdir -p "$DIR"

# --- directory structure ---
mkdir -p "$DIR"/{public,src,config,routes,views/layouts,storage/{framework,logs,sessions},docker}

# --- composer.json ---
cat > "$DIR/composer.json" <<EOF
{
    "name": "luminus/${DIRNAME}",
    "type": "project",
    "require": {
        "php": ">=8.2"
    },
    "autoload": {
        "psr-4": {
            "App\\\\": "app/"
        }
    }
}
EOF

# --- public/index.php ---
cat > "$DIR/public/index.php" <<'PHPEOF'
<?php

require __DIR__ . '/../vendor/autoload.php';

$app = new Luminus\App();
$app->loadEnv();
$app->loadConfig(require __DIR__ . '/../config/app.php');
$app->loadRoutes(__DIR__ . '/../routes/web.php');
$app->run();
PHPEOF

# --- public/router.php ---
cat > "$DIR/public/router.php" <<'PHPEOF'
<?php

$uri = parse_url($_SERVER['REQUEST_URI'], PHP_URL_PATH);

if ($uri !== '/' && file_exists(__DIR__ . $uri)) {
    return false;
}

chdir(__DIR__);
require __DIR__ . '/index.php';
PHPEOF

# --- config/app.php ---
cat > "$DIR/config/app.php" <<'PHPEOF'
<?php

return [
    'debug' => env('APP_DEBUG', true),
    'env' => env('APP_ENV', 'development'),
    'url' => env('APP_URL', 'http://localhost:8080'),
    'views_path' => __DIR__ . '/../views',
    'storage_path' => __DIR__ . '/../storage',

    'database' => [
        'driver' => env('DB_DRIVER', 'mysql'),
        'host' => env('DB_HOST', '127.0.0.1'),
        'port' => env('DB_PORT', '3306'),
        'database' => env('DB_DATABASE', $DIRNAME),
        'username' => env('DB_USERNAME', 'root'),
        'password' => env('DB_PASSWORD', ''),
        'charset' => 'utf8mb4',
    ],
];
PHPEOF

# --- .env.example ---
cat > "$DIR/.env.example" <<EOF
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=${DIRNAME}
DB_USERNAME=root
DB_PASSWORD=
EOF

# --- .env ---
cp "$DIR/.env.example" "$DIR/.env"

# --- .gitignore ---
cat > "$DIR/.gitignore" <<'EOF'
vendor/
.env
storage/framework/
storage/logs/*.log
EOF

# --- routes/web.php ---
cat > "$DIR/routes/web.php" <<'PHPEOF'
<?php

use Luminus\Request;
use Luminus\Response;
use Luminus\View;

$router->get('/', function (Request $req, View $view): string {
    return $view->render('welcome', ['name' => 'Luminus']);
});

$router->get('/hello/{name}', function (string $name): string {
    return "<h1>Hello, {$name}!</h1>";
});

$router->get('/api/ping', function (Response $res): Response {
    return $res->json(['pong' => true, 'time' => time()]);
});
PHPEOF

# --- views/layouts/main.php ---
cat > "$DIR/views/layouts/main.php" <<'PHPEOF'
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= $title ?? 'Luminus' ?></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #333; background: #fafafa; }
    </style>
</head>
<body>
    <?php $this->renderSection('content') ?>
</body>
</html>
PHPEOF

# --- views/welcome.php ---
cat > "$DIR/views/welcome.php" <<'PHPEOF'
<?php $this->layout('layouts.main') ?>

<?php $this->section('content') ?>
<div style="text-align:center;padding:4rem 2rem;">
    <h1>Welcome to <?= $name ?></h1>
    <p style="color:#666;font-size:1.2rem;">Your Luminus project is ready.</p>
</div>
<?php $this->endSection() ?>
PHPEOF

# --- app/Controllers/HomeController.php ---
mkdir -p "$DIR/app/Controllers"
cat > "$DIR/app/Controllers/HomeController.php" <<'PHPEOF'
<?php

namespace App\Controllers;

use Luminus\Request;
use Luminus\View;

class HomeController
{
    public function index(Request $req, View $view): string
    {
        return $view->render('welcome', ['name' => 'Luminus']);
    }
}
PHPEOF

# --- Makefile ---
cat > "$DIR/Makefile" <<'MAKEEOF'
APP_PORT ?= 8080

.PHONY: dev setup

dev:
	php -S localhost:$(APP_PORT) -t public public/router.php

setup:
	@cp -n .env.example .env 2>/dev/null || true
	composer dump-autoload
	@mkdir -p storage/framework storage/logs storage/sessions
	@chmod -R 775 storage
	@echo "Done. Run: make dev"
MAKEEOF

# --- Dockerfile ---
cat > "$DIR/Dockerfile" <<'DOCKEREOF'
FROM php:8.2-fpm-alpine

RUN apk add --no-cache nginx supervisor curl \
    && docker-php-ext-install pdo pdo_mysql

COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

WORKDIR /var/www/html
COPY . .

RUN mkdir -p storage/framework storage/logs storage/sessions \
    && chmod -R 775 storage \
    && chown -R www-data:www-data storage

RUN composer install --no-dev --optimize-autoloader --no-interaction

COPY docker/nginx.conf /etc/nginx/http.d/default.conf

EXPOSE 80

CMD php-fpm -D && nginx -g "daemon off;"
DOCKEREOF

# --- docker/nginx.conf ---
cat > "$DIR/docker/nginx.conf" <<'NGINXEOF'
server {
    listen 80;
    root /var/www/html/public;
    index index.php;
    charset utf-8;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        fastcgi_pass 127.0.0.1:9000;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\.(ht|git) { deny all; }
}
NGINXEOF

# --- storage/.gitkeep ---
touch "$DIR/storage/.gitkeep"

echo -e "${GREEN}✓${NC} Project structure created"
echo ""

# --- Copy framework source ---
MINIPHP_DIR="$(cd "$(dirname "$0")/.." && pwd)"

if [ -d "$MINIPHP_DIR/src" ]; then
    cp -r "$MINIPHP_DIR/src/." "$DIR/src/"
    cp "$MINIPHP_DIR/composer.json" "$DIR/composer.luminus.json"
    echo -e "${GREEN}✓${NC} Framework source copied (src/)"
else
    echo -e "${RED}Warning:${NC} Could not find Luminus src/. Copy manually."
fi

# --- composer install ---
echo ""
echo -e "${CYAN}Installing dependencies...${NC}"
cd "$DIR"

# Merge composer files to keep luminus autoload
php -r "
    \$a = json_decode(file_get_contents('composer.json'), true);
    \$b = json_decode(file_get_contents('composer.luminus.json'), true);
    \$a['autoload']['psr-4']['Luminus\\\\'] = 'src/';
    \$a['autoload']['files'] = ['src/helpers.php'];
    if (isset(\$b['require'])) {
        \$filtered = array_diff_key(\$b['require'], ['luminus/breeze' => 1]);
        \$a['require'] = array_merge(\$a['require'], \$filtered);
    }
    file_put_contents('composer.json', json_encode(\$a, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES));
"
rm composer.luminus.json

composer dump-autoload 2>&1 | sed 's/^/  /'

# --- Optional Breeze auth scaffolding ---
BREEZE_INSTALLED=0
echo ""
read -p "Install Breeze auth scaffolding? [y/N] " breeze_answer
if [[ "$breeze_answer" =~ ^[Yy]$ ]]; then
    echo ""
    echo -e "${CYAN}Adding Breeze...${NC}"

    php -r "
        \$c = json_decode(file_get_contents('composer.json'), true);
        \$c['repositories'] = [
            ['type' => 'path', 'url' => '$MINIPHP_DIR'],
            ['type' => 'path', 'url' => '$MINIPHP_DIR/packages/luminus-breeze']
        ];
        \$c['require']['luminus/breeze'] = '@dev';
        \$c['minimum-stability'] = 'dev';
        \$c['prefer-stable'] = true;
        file_put_contents('composer.json', json_encode(\$c, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES));
    "

    composer update --no-interaction 2>&1 | sed 's/^/  /'

    cat > public/index.php <<'PHPEOF'
<?php

require __DIR__ . '/../vendor/autoload.php';

use Luminus\Breeze\BreezeServiceProvider;
use Luminus\CsrfMiddleware;
use Luminus\StartSessionMiddleware;

$app = new Luminus\App();
$app->loadEnv();
$app->loadConfig(require __DIR__ . '/../config/app.php');

$app->addMiddleware(new StartSessionMiddleware());
$app->addMiddleware(new CsrfMiddleware());

$app->registerProviders([
    BreezeServiceProvider::class,
]);

$app->loadRoutes(__DIR__ . '/../routes/web.php');
$app->run();
PHPEOF

    if [ -f vendor/bin/breeze ]; then
        php vendor/bin/breeze install 2>&1 | sed 's/^/  /'
    fi

    BREEZE_INSTALLED=1
    echo -e "${GREEN}✓${NC} Breeze auth scaffolding installed"
fi

echo ""
echo -e "${GREEN}╔══════════════════════════════════════╗${NC}"
echo -e "${GREEN}║  Luminus project ready!              ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════╝${NC}"
echo ""
echo -e "  ${CYAN}Project:${NC}  $DIR"
echo -e "  ${CYAN}Run:${NC}      cd $DIR && make dev"
echo -e "  ${CYAN}Open:${NC}     http://localhost:8080"

if [ "$BREEZE_INSTALLED" -eq 1 ]; then
    echo ""
    echo -e "  ${CYAN}Auth:${NC}    /login  |  /register"
    echo -e "  ${CYAN}Next:${NC}    php bin/migrate up"
fi

echo ""
