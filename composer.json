{
    "name": "luminus/luminus",
    "description": "Minimal PHP framework - zero dependencies",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Luminus\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Example\\": "example/"
        }
    },
    "require": {
        "php": ">=8.2",
        "pda/pheanstalk": "^5.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    }
}
